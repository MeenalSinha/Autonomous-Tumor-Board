# Environment Configuration Example
# Copy this file to .env and customize as needed

# Application Settings
APP_NAME=Autonomous Tumor Board
APP_VERSION=1.1.0
ENVIRONMENT=development

# API Settings (if using FastAPI backend)
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Streamlit Settings (if using Streamlit UI)
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# Data Paths
DATA_DIR=./data
OUTPUTS_DIR=./data/outputs
UPLOADS_DIR=./data/uploads
GUIDELINES_DIR=./data/guidelines

# Logging
LOG_LEVEL=INFO
LOG_FILE=./app.log

# Model Settings (simulated - for future real model integration)
# MODEL_PATH=./models/checkpoint
# MODEL_DEVICE=cpu
# MODEL_BATCH_SIZE=1

# Safety Settings
DISCLAIMER_ENABLED=true
HUMAN_REVIEW_REQUIRED=true

# Feature Flags
ENABLE_AGENT_DISAGREEMENT_DETECTION=true
ENABLE_CLINICIAN_ACTION_CHECKLIST=true
ENABLE_LONGITUDINAL_TRACKING=true
ENABLE_CONFIDENCE_DISPLAY=true

# Development Settings
DEBUG=false
TESTING=false

# Note: This is a demonstration project
# Do NOT use in clinical settings without proper validation and approval
